    "# =========================================================\n",
    "# COVID NETWORK (HIGHLIGHT PATHS TO COVID + TOP 10 EDGES)\n",
    "# =========================================================\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import warnings\n",
    "import matplotlib.pyplot as plt\n",
    "import networkx as nx\n",
    "\n",
    "from sklearn.linear_model import LogisticRegressionCV, LassoCV\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "# =========================================================\n",
    "# 1. LOAD DATA\n",
    "# =========================================================\n",
    "data = pd.read_csv("data/merged.csv")\n",
    "\n",
    "# =========================================================\n",
    "# 2. CLEAN + RENAME\n",
    "# =========================================================\n",
    "data.columns = [c.strip().lower() for c in data.columns]\n",
    "\n",
    "data = data.rename(columns={\n",
    "    'aches': 'Aches',\n",
    "    'age': 'age',\n",
    "    'chest_pain': 'ChestPain',\n",
    "    'chills': 'Chills',\n",
    "    'conjunctivitis': 'RedEye',\n",
    "    'cough': 'Cough',\n",
    "    'diarrhea': 'Diarrhea',\n",
    "    'disease': 'COVID',\n",
    "    'fatigue': 'Fatigue',\n",
    "    'fever': 'Fever',\n",
    "    'gender': 'gender',\n",
    "    'headache': 'Headache',\n",
    "    'nausea': 'Nausea',\n",
    "    'running_nose': 'RunnyNose',\n",
    "    'short_breath': 'ShortBreath',\n",
    "    'vomiting': 'Vomit',\n",
    "    'wheezing': 'Wheeze'\n",
    "})\n",
    "\n",
    "cols = [\n",
    "    'Aches','age','ChestPain','Chills','RedEye','Cough',\n",
    "    'Diarrhea','COVID','Fatigue','Fever','gender',\n",
    "    'Headache','Nausea','RunnyNose','ShortBreath',\n",
    "    'Vomit','Wheeze'\n",
    "]\n",
    "data = data[cols].copy()\n",
    "\n",
    "# =========================================================\n",
    "# 3. CLEAN DATA\n",
    "# =========================================================\n",
    "data['age'] = pd.to_numeric(data['age'], errors='coerce')\n",
    "data['age'] = data['age'].fillna(data['age'].median())\n",
    "data['age'] = (data['age'] >= 50).astype(int)\n",
    "\n",
    "for col in data.columns:\n",
    "    if col != 'age':\n",
    "        data[col] = pd.to_numeric(data[col], errors='coerce')\n",
    "        data[col] = data[col].fillna(0)\n",
    "        data[col] = (data[col] > 0).astype(int)\n",
    "\n",
    "# =========================================================\n",
    "# 4. LEARN EDGES (TOP-K + STRONG)\n",
    "# =========================================================\n",
    "variables = list(data.columns)\n",
    "\n",
    "edges = []\n",
    "TOP_K = 3\n",
    "THRESHOLD = 0.25\n",
    "\n",
    "for target in variables:\n",
    "    predictors = [v for v in variables if v != target]\n",
    "\n",
    "    X = data[predictors]\n",
    "    y = data[target]\n",
    "\n",
    "    if y.nunique() <= 1:\n",
    "        continue\n",
    "\n",
    "    scaler = StandardScaler()\n",
    "    X_scaled = scaler.fit_transform(X)\n",
    "\n",
    "    if y.nunique() == 2:\n",
    "        model = LogisticRegressionCV(cv=5, penalty='l1', solver='liblinear', max_iter=5000)\n",
    "        model.fit(X_scaled, y)\n",
    "        coef = model.coef_[0]\n",
    "    else:\n",
    "        model = LassoCV(cv=5, max_iter=10000)\n",
    "        model.fit(X_scaled, y)\n",
    "        coef = model.coef_\n",
    "\n",
    "    coef_pairs = list(zip(predictors, coef))\n",
    "    coef_pairs = sorted(coef_pairs, key=lambda x: abs(x[1]), reverse=True)\n",
    "\n",
    "    for pred, c in coef_pairs[:TOP_K]:\n",
    "        if abs(c) > THRESHOLD:\n",
    "            edges.append((pred, target, float(c)))\n",
    "\n",
    "# =========================================================\n",
    "# 5. REMOVE BIDIRECTIONAL EDGES\n",
    "# =========================================================\n",
    "edge_dict = {}\n",
    "\n",
    "for u, v, c in edges:\n",
    "    if (v, u) in edge_dict:\n",
    "        if abs(c) > abs(edge_dict[(v, u)]):\n",
    "            del edge_dict[(v, u)]\n",
    "            edge_dict[(u, v)] = c\n",
    "    else:\n",
    "        edge_dict[(u, v)] = c\n",
    "\n",
    "final_edges = [(u, v, c) for (u, v), c in edge_dict.items()]\n",
    "\n",
    "# =========================================================\n",
    "# 6. BUILD GRAPH\n",
    "# =========================================================\n",
    "G = nx.DiGraph()\n",
    "\n",
    "for col in data.columns:\n",
    "    G.add_node(col)\n",
    "\n",
    "for u, v, c in final_edges:\n",
    "    G.add_edge(u, v, weight=c)\n",
    "\n",
    "# =========================================================\n",
    "# 7. FIND PATHS TO COVID\n",
    "# =========================================================\n",
    "covid_paths = set()\n",
    "\n",
    "for node in G.nodes():\n",
    "    if node != \"COVID\":\n",
    "        try:\n",
    "            paths = nx.all_simple_paths(G, source=node, target=\"COVID\", cutoff=3)\n",
    "            for path in paths:\n",
    "                for i in range(len(path)-1):\n",
    "                    covid_paths.add((path[i], path[i+1]))\n",
    "        except:\n",
    "            pass\n",
    "\n",
    "# =========================================================\n",
    "# 8. TOP 10 STRONGEST EDGES\n",
    "# =========================================================\n",
    "sorted_edges = sorted(G.edges(data=True), key=lambda x: abs(x[2]['weight']), reverse=True)\n",
    "top_edges = [(u, v) for u, v, _ in sorted_edges[:10]]\n",
    "\n",
    "# =========================================================\n",
    "# 9. DRAW GRAPH (CLEAN + HIGHLIGHT)\n",
    "# =========================================================\n",
    "plt.figure(figsize=(18, 12))\n",
    "\n",
    "pos = nx.spring_layout(G, k=1.5, seed=42)\n",
    "\n",
    "# draw nodes\n",
    "nx.draw_networkx_nodes(G, pos, node_size=2500)\n",
    "nx.draw_networkx_labels(G, pos, font_size=10)\n",
    "\n",
    "# draw all edges faint\n",
    "nx.draw_networkx_edges(G, pos, alpha=0.15)\n",
    "\n",
    "# highlight top edges (thick black)\n",
    "nx.draw_networkx_edges(\n",
    "    G, pos,\n",
    "    edgelist=top_edges,\n",
    "    width=3,\n",
    "    edge_color='black',\n",
    "    arrows=True\n",
    ")\n",
    "\n",
    "# highlight COVID paths (RED)\n",
    "nx.draw_networkx_edges(\n",
    "    G, pos,\n",
    "    edgelist=list(covid_paths),\n",
    "    width=2.5,\n",
    "    edge_color='red',\n",
    "    arrows=True\n",
    ")\n",
    "\n",
    "# labels only for top edges (avoid clutter)\n",
    "edge_labels = {(u, v): f\"{G[u][v]['weight']:.2f}\" for u, v in top_edges}\n",
    "nx.draw_networkx_edge_labels(G, pos, edge_labels=edge_labels, font_size=9)\n",
    "\n",
    "plt.title(\"COVID Network (Top 10 Edges)\", fontsize=16)\n",
    "plt.axis(\"off\")\n",
    "plt.show()"
   ]
  }
 ],
